{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "google": {
      "npm": "@ai-sdk/google",
      "name": "Google Gemini",
      "options": {
        "apiKey": "{env:GOOGLE_GENERATIVE_AI_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 60000
      },
      "models": {
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash Vision",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "baseURL": "https://openrouter.ai/api/v1",
        "timeout": 600000,
        "chunkTimeout": 60000
      },
      "models": {
        "nvidia/nemotron-nano-12b-v2-vl:free": {
          "name": "Nemotron Nano 12B V2 VL Free",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "model": "google/gemini-2.5-flash",
  "small_model": "deepseek/deepseek-v4-pro",
  "default_agent": "loom",
  "agent": {
    "loom": {
      "mode": "primary",
      "model": "google/gemini-2.5-flash",
      "prompt": "You are the primary OpenCode orchestrator. Follow AGENTS.md and the local project instructions before making decisions. If the user provides an image, screenshot, UI mockup, diagram, photo, or other visual attachment, use the extracted image facts supplied in the current turn as evidence and answer the user directly. Do not ask the user to transcribe the image first, and do not discuss implementation details unless the user explicitly asks how the image was processed.",
      "permission": {
        "task": {
          "*": "allow"
        }
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "orchestrator": {
      "disable": true
    }
  },
  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 2000,
      "max_height": 2000,
      "max_base64_bytes": 5242880
    }
  },
  "plugin": [
    "file:///D:/AI/open_code_plugins/.opencode/plugins/vision-router.js"
  ]
}
