{
  "$schema": "https://raw.githubusercontent.com/pgermishuys/opencode-weave/v0.8.0/schema/weave-config.schema.json",
  "agents": {
    "loom": { "model": "deepseek/deepseek-v4-pro" },
    "tapestry": { "model": "deepseek/deepseek-v4-pro" },
    "shuttle": { "model": "deepseek/deepseek-v4-pro" },
    "pattern": { "model": "google/gemini-2.5-flash" },
    "thread": { "model": "deepseek/deepseek-v4-pro" },
    "spindle": { "model": "deepseek/deepseek-v4-pro" },
    "weft": { "model": "google/gemini-2.5-flash" },
    "warp": { "model": "google/gemini-2.5-flash" }
  },
  "background": {
    "defaultConcurrency": 2
  },
  "continuation": {
    "recovery": {
      "compaction": true
    },
    "idle": {
      "enabled": true,
      "work": true,
      "workflow": true,
      "todo_prompt": true
    }
  }
}
